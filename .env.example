# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme_root
MONGO_DB_NAME=pebbles
MONGO_APP_USER=appuser
MONGO_APP_PASSWORD=changeme_app

# Used by the backend — points at the mongo service inside docker network
MONGODB_URI=mongodb://appuser:changeme_app@mongodb:27017/pebbles?authSource=pebbles

# ── OpenTelemetry / SigNoz ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=pebbles-backend
# HTTP endpoint of signoz-otel-collector inside the Docker network
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4318

# ── Backend ────────────────────────────────────────────────────────────────────
JWT_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
